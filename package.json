{
  "name": "catalunya-opendata-mcp",
  "version": "0.1.3",
  "description": "Read-only MCP server for searching, describing, and querying Catalunya open data (Socrata and IDESCAT).",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "catalunya",
    "catalonia",
    "open-data",
    "opendata",
    "dades-obertes",
    "generalitat-de-catalunya",
    "idescat",
    "jsonstat",
    "estadistica",
    "socrata",
    "soda",
    "claude",
    "anthropic",
    "llm-tools",
    "typescript"
  ],
  "homepage": "https://github.com/aalises/catalunya-opendata-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aalises/catalunya-opendata-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/aalises/catalunya-opendata-mcp/issues"
  },
  "author": "Albert Alises",
  "type": "module",
  "private": true,
  "bin": {
    "catalunya-opendata-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/index.js",
    "start": "node dist/index.js",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "canary:socrata": "npm run build && node scripts/socrata-live-canary.mjs",
    "canary:idescat": "npm run build && node scripts/idescat-live-canary.mjs",
    "eval:canary": "npm run build && node scripts/evaluate-mcp.mjs --profile=canary",
    "eval:stress": "npm run build && node scripts/evaluate-mcp.mjs --profile=stress",
    "eval:record:canary": "npm run build && node scripts/evaluate-mcp.mjs --profile=canary --mode=record",
    "eval:replay:canary": "npm run build && node scripts/evaluate-mcp.mjs --profile=canary --mode=replay",
    "eval:record:stress": "npm run build && node scripts/evaluate-mcp.mjs --profile=stress --mode=record",
    "eval:replay:stress": "npm run build && node scripts/evaluate-mcp.mjs --profile=stress --mode=replay",
    "package:size": "node scripts/package-size.mjs",
    "refresh:idescat": "tsx scripts/refresh-idescat.ts",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "npm run typecheck && npm run lint && npm test && npm run smoke && npm run package:size",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT"
}
