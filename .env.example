# Runtime
NODE_ENV=development
LOG_LEVEL=info
CATALUNYA_MCP_TRANSPORT=stdio

# Safety caps
CATALUNYA_MCP_MAX_RESULTS=100
CATALUNYA_MCP_REQUEST_TIMEOUT_MS=30000
CATALUNYA_MCP_RESPONSE_MAX_BYTES=262144
CATALUNYA_MCP_IDESCAT_UPSTREAM_READ_BYTES=8388608
CATALUNYA_MCP_BCN_UPSTREAM_READ_BYTES=2097152
CATALUNYA_MCP_BCN_GEO_SCAN_MAX_ROWS=50000
CATALUNYA_MCP_BCN_GEO_SCAN_BYTES=67108864

# Source credentials
SOCRATA_APP_TOKEN=
